# Vibehack — copy to .env if you want to keep local environment overrides.
# Export these variables in your shell before running npm scripts, or pass them inline.

# ─── Server ──────────────────────────────────────────────────────────────────
# PORT=9080
# VH_DB_PATH=./vibehack.db
# VH_WORKERS=on               # set to `off` to boot server without workers

# ─── Event scanners ───────────────────────────────────────────────────────────
# LUMA_CALENDARS=genai-collective,genai-sf,oss4ai
# LUMA_INTERVAL_MS=1800000
# DEVPOST_INTERVAL_MS=3600000
# DEVPOST_MAX_PAGES=2          # capped 1..10 for paginated Devpost API runs
# DEVPOST_SEARCH_TERMS=ai,agent,agents,vibe coding
# DEVPOST_REQUEST_DELAY_MS=750 # polite delay between Devpost API requests
# HEADLESS_INTERVAL_MS=7200000
# HEADLESS_ON_START=1
