# Vibehack — copy to .env and fill in. The server auto-loads .env at startup
# via `node --env-file=.env` (pass with `npm run dev` or set via environment).

# ─── Server ──────────────────────────────────────────────────────────────────
# PORT=5173
# VH_DB_PATH=./vibehack.db
# VH_WORKERS=on               # set to `off` to boot server without workers

# ─── MLH Hackathon scanner ───────────────────────────────────────────────────
# MLH_FEEDS=https://mlh.io/seasons/2026/events.rss,https://mlh.io/seasons/2025/events.rss
# MLH_INTERVAL_MS=900000

# ─── Gmail credit-hunter ─────────────────────────────────────────────────────
# Create an OAuth2 "Desktop app" client in Google Cloud Console, enable Gmail API.
# Run a one-time consent flow to obtain a refresh token (scope: gmail.readonly).
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_QUERY=newer_than:7d (credit OR grant OR promo OR bounty)
# GMAIL_INTERVAL_MS=300000

# ─── Auth (only needed for public/non-localhost deploy) ──────────────────────
# VH_TOKEN=                   # single-user password; `?k=<token>` sets an httpOnly cookie
